@base <http://example.org/videojuegos> .
@prefix : <http://example.org/videojuegos#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


# ====================================================================
# CLASES
# ====================================================================

:Videojuego rdf:type owl:Class ;
    rdfs:label "Videojuego" ;
    rdfs:comment "Obra intelectual, independiente de la plataforma" .

:Lanzamiento rdf:type owl:Class ;
    rdfs:label "Lanzamiento" ;
    rdfs:comment "Edicion especifica de un videojuego en una plataforma concreta" .

:Plataforma rdf:type owl:Class ;
    rdfs:label "Plataforma" ;
    rdfs:comment "Clase padre para todos los tipos de plataforma" .

:Consola rdf:type owl:Class ;
    rdfs:subClassOf :Plataforma ;
    rdfs:label "Consola" ;
    rdfs:comment "Plataforma de tipo consola (Xbox, PlayStation, Switch)" .

:PC rdf:type owl:Class ;
    rdfs:subClassOf :Plataforma ;
    rdfs:label "PC" ;
    rdfs:comment "Plataforma de tipo PC (Windows, Mac, Linux)" .

:Genero rdf:type owl:Class ;
    rdfs:label "Genero" ;
    rdfs:comment "Categoria o genero de un videojuego" .

:Desarrollador rdf:type owl:Class ;
    rdfs:label "Desarrollador" ;
    rdfs:comment "Estudio o empresa que desarrollo el videojuego" .

:Editor rdf:type owl:Class ;
    rdfs:label "Editor" ;
    rdfs:comment "Empresa que publico el lanzamiento en una plataforma" .

:VentaRegional rdf:type owl:Class ;
    rdfs:label "Venta regional" ;
    rdfs:comment "Ventas de un lanzamiento en una region especifica" .

:LanzamientoRegional rdf:type owl:Class ;
    rdfs:label "Lanzamiento regional" ;
    rdfs:comment "Fecha de lanzamiento en una region especifica" .


# ====================================================================
# PROPIEDADES DE DATO (data -> literal)
# ====================================================================

:nombre rdf:type owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:label "nombre" ;
    rdfs:comment "Nombre legible de cualquier entidad" .

:region rdf:type owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:label "region" ;
    rdfs:comment "Codigo de region (NA, EU, JP, Other)" .

:monto rdf:type owl:DatatypeProperty ;
    rdfs:domain :VentaRegional ;
    rdfs:range xsd:decimal ;
    rdfs:label "monto" ;
    rdfs:comment "Valor de ventas en millones de unidades" .

:fecha rdf:type owl:DatatypeProperty ;
    rdfs:domain :LanzamientoRegional ;
    rdfs:range xsd:date ;
    rdfs:label "fecha" ;
    rdfs:comment "Fecha de lanzamiento en formato ISO" .

:precio rdf:type owl:DatatypeProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range xsd:decimal ;
    rdfs:label "precio" ;
    rdfs:comment "Precio en USD" .

:metacriticScore rdf:type owl:DatatypeProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range xsd:integer ;
    rdfs:label "puntuacion Metacritic" ;
    rdfs:comment "Puntuacion de Metacritic (1-100; 0 indica ausencia de dato)" .

:reseñasPositivas rdf:type owl:DatatypeProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range xsd:integer ;
    rdfs:label "resenas positivas" ;
    rdfs:comment "Numero de resenas positivas en Steam" .

:reseñasNegativas rdf:type owl:DatatypeProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range xsd:integer ;
    rdfs:label "resenas negativas" ;
    rdfs:comment "Numero de resenas negativas en Steam" .

:tiempoJuego rdf:type owl:DatatypeProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range xsd:integer ;
    rdfs:label "tiempo de juego" ;
    rdfs:comment "Tiempo promedio jugado en minutos" .

:peakCcu rdf:type owl:DatatypeProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range xsd:integer ;
    rdfs:label "pico de concurrentes" ;
    rdfs:comment "Maximo de jugadores concurrentes en Steam" .


# ====================================================================
# PROPIEDADES DE OBJETO (entidad -> entidad)
# ====================================================================

:perteneceAGenero rdf:type owl:ObjectProperty ;
    rdfs:domain :Videojuego ;
    rdfs:range :Genero ;
    rdfs:label "pertenece a genero" ;
    rdfs:comment "Genero(s) al que pertenece el videojuego" .

:desarrolladoPor rdf:type owl:ObjectProperty ;
    rdfs:domain :Videojuego ;
    rdfs:range :Desarrollador ;
    rdfs:label "desarrollado por" ;
    rdfs:comment "Estudio o empresa que desarrollo el videojuego" .

:tieneLanzamiento rdf:type owl:ObjectProperty ;
    rdfs:domain :Videojuego ;
    rdfs:range :Lanzamiento ;
    rdfs:label "tiene lanzamiento" ;
    rdfs:comment "Asocia un videojuego con sus lanzamientos en distintas plataformas" .

:enPlataforma rdf:type owl:ObjectProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range :Plataforma ;
    rdfs:label "en plataforma" ;
    rdfs:comment "Plataforma en la que se publico el lanzamiento" .

:publicadoPor rdf:type owl:ObjectProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range :Editor ;
    rdfs:label "publicado por" ;
    rdfs:comment "Empresa que publico el lanzamiento en la plataforma" .

:tieneVenta rdf:type owl:ObjectProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range :VentaRegional ;
    rdfs:label "tiene venta" ;
    rdfs:comment "Ventas regionales asociadas al lanzamiento" .

:fechaLanzamiento rdf:type owl:ObjectProperty ;
    rdfs:domain :Lanzamiento ;
    rdfs:range :LanzamientoRegional ;
    rdfs:label "fecha de lanzamiento" ;
    rdfs:comment "Fecha(s) de lanzamiento del juego por region" .

:tieneDemo rdf:type owl:ObjectProperty ;
    rdfs:domain :Videojuego ;
    rdfs:range :Lanzamiento ;
    rdfs:label "tuvo version demo" .

:tienePlaytest rdf:type owl:ObjectProperty ;
    rdfs:domain :Videojuego ;
    rdfs:range :Lanzamiento ;
    rdfs:label "tuvo version playtest" .
