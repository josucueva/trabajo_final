@prefix :      <http://example.org/videojuegos#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .


# ====================================================================
# VALIDACIÓN 1: OBLIGATORIEDAD
# Todo Videojuego debe tener al menos un género (:perteneceAGenero)
# ====================================================================
# Sustento real: Xbox 64.63% y PlayStation 87.14% de genre vacío
# ====================================================================

:VideojuegoShape a sh:NodeShape ;
    sh:targetClass :Videojuego ;
    sh:message "Todo Videojuego debe tener al menos un genero asignado" ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path :perteneceAGenero ;
        sh:minCount 1 ;
        sh:message "El videojuego no tiene ningun genero asignado"
    ] .


# ====================================================================
# VALIDACIÓN 2: TIPO DE LITERAL
# VentaRegional.monto debe ser xsd:decimal
# ====================================================================
# Sustento real: columnas NA_Sales, EU_Sales, JP_Sales, Other_Sales
#                en vgsales son float64 consistentes
# ====================================================================

:VentaRegionalMontoShape a sh:NodeShape ;
    sh:targetClass :VentaRegional ;
    sh:message "VentaRegional debe tener monto como xsd:decimal" ;
    sh:property [
        sh:path :monto ;
        sh:datatype xsd:decimal ;
        sh:message "El monto de VentaRegional debe ser un valor decimal (xsd:decimal)"
    ] .


# ====================================================================
# VALIDACIÓN 3: RANGO DE VALORES
# Lanzamiento.metacriticScore debe estar entre 1 y 100
# (0 se considera "sin dato" y se excluye)
# ====================================================================
# Sustento real: 96.2% de registros Steam tienen metacritic_score = 0
# ====================================================================

:MetacriticScoreShape a sh:NodeShape ;
    sh:targetClass :Lanzamiento ;
    sh:message "metacriticScore debe estar entre 1 y 100" ;
    sh:property [
        sh:path :metacriticScore ;
        sh:minInclusive 1 ;
        sh:maxInclusive 100 ;
        sh:message "metacriticScore debe ser un entero entre 1 y 100 (0 indica ausencia de dato)"
    ] .


# ====================================================================
# VALIDACIÓN 4: SHAPE CERRADA
# VentaRegional SOLO puede tener las propiedades :region y :monto
# (ademas de rdf:type obviamente)
# ====================================================================
# Sustento: decision de diseno para evitar propiedades no previstas
#           por errores de transformacion
# ====================================================================

:VentaRegionalClosedShape a sh:NodeShape ;
    sh:targetClass :VentaRegional ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [
        sh:path :region ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Toda VentaRegional debe tener exactamente una region"
    ] ;
    sh:property [
        sh:path :monto ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message "Toda VentaRegional debe tener exactamente un monto decimal"
    ] ;
    sh:message "VentaRegional solo puede tener las propiedades :region y :monto (ademas de rdf:type)" .
